# 应用名称
VITE_APP_NAME=OpenClaw 助手

# 飞书应用 ID（需在飞书开放平台创建应用后获取）
VITE_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx

# 飞书 OAuth 回调地址（需在飞书开放平台配置）
VITE_FEISHU_REDIRECT_URI=http://localhost:3000/auth/callback

# 后端 API 地址
VITE_API_BASE_URL=http://localhost:8080

# Star-Office-UI 地址（留空时将回退到本地 mock）
VITE_STAR_OFFICE_URL=

# 是否开启真实 Star-Office 本地联调模式（需要提供上游 frontend 目录）
VITE_STAR_OFFICE_REAL_DEV_ENABLED=false

# 真实 Star-Office 本地联调基础路径
VITE_STAR_OFFICE_REAL_DEV_BASE=/star-office

# 真实 Star-Office 上游目录（可填仓库根目录或 frontend 目录）
VITE_STAR_OFFICE_UPSTREAM_DIR=./vendor/Star-Office-UI

# 是否开启 Mock 模式（开发阶段，无后端时使用）
VITE_MOCK_ENABLED=true

# 是否开启本地 Star-Office mock（开发阶段推荐开启）
VITE_STAR_OFFICE_MOCK_ENABLED=true

# 本地 Star-Office mock 基础路径
VITE_STAR_OFFICE_MOCK_BASE=/__mock/star-office
